{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "declaration": true,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": [
        "src"
    ],
    "exclude": [
        "src/**/*.test.ts"
    ]
}
